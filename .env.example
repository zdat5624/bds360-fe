# ==============================================================================
# TEMPLATE BIEN MOI TRUONG (.env.example)
# 
# HUONG DAN:
# 1. Copy toan bo noi dung file nay.
# 2. Tao mot file moi ten la `.env.local` o cung thu muc.
# 3. Dan noi dung vao va thay the cac gia tri gia bang key that cua ban.
#
# [!] CHU Y: TUYET DOI KHONG ghi mat khau hoac token that vao file nay.
# ==============================================================================

# --- 1. SYSTEM CONFIG ---
# Chi dinh moi truong chay app (development | production | test)
# Mac dinh khi dev local nen de la development
NODE_ENV=development

# --- 2. API ENDPOINTS ---
# URL cua Backend API.
# Tien to NEXT_PUBLIC_ cho phep Client-side (Trinh duyet) truy cap duoc.
# Dinh dang chuan: Khong co dau "/" o cuoi URL.
NEXT_PUBLIC_API_URL=your_api_url_here

NEXT_PUBLIC_WS_URL=your_socket_url_here

# --- 3. THIRD-PARTY SERVICES ---
# Mapbox API Key dung de render ban do.
# Cach lay: Dang nhap https://account.mapbox.com/ -> Tokens -> Create a token
NEXT_PUBLIC_MAPBOX_KEY=your_key_here

# Google OAuth Client ID (Neu co su dung Google Login)
# Cach lay: Dang nhap Google Cloud Console -> Credentials -> Create Credentials -> OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here